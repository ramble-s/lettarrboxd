# Letterboxd Configuration
# Your Letterboxd url (your username is the part after letterboxd.com/user/)
LETTERBOXD_URL=https://letterboxd.com/yourusernamehere/watchlist/

# Radarr Configuration
# Base URL of your Radarr instance (include http/https and port)
RADARR_API_URL=http://localhost:7878
# API key from Radarr Settings > General > Security > API Key
RADARR_API_KEY=your_radarr_api_key_here
# Quality profile name (must match exactly - case sensitive)
RADARR_QUALITY_PROFILE=HD-1080p
# When movies become available for download (announced, inCinemas, released)
RADARR_MINIMUM_AVAILABILITY=released
# Add movies in unmonitored state (true to add as unmonitored, false to add as monitored)
# RADARR_ADD_UNMONITORED=false

# Sonarr Configuration (optional)
# Set SONARR_ENABLED=true to activate Sonarr TV sync. When enabled, the three
# SONARR_* vars below are all required; when disabled (default), they can be omitted.
SONARR_ENABLED=false
# Base URL of your Sonarr instance (include http/https and port)
# SONARR_API_URL=http://localhost:8989
# API key from Sonarr Settings > General > Security > API Key
# SONARR_API_KEY=your_sonarr_api_key_here
# Quality profile name in Sonarr (must match exactly - case sensitive)
# SONARR_QUALITY_PROFILE=HD-1080p

# Application Configuration
# Directory for storing application data (persistent storage)
DATA_DIR=./data
# How often to check for new movies in minutes (minimum 10)
CHECK_INTERVAL_MINUTES=60
# Environment mode (development, production, test)
NODE_ENV=development
# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# Movie Limiting (optional - both must be specified together)
# Number of movies to sync from watchlist
# LETTERBOXD_TAKE_AMOUNT=10
# Strategy for selecting movies (newest or oldest)
# LETTERBOXD_TAKE_STRATEGY=newest

# Diary cleanup (optional) - deletes Radarr/Sonarr items tagged in your Letterboxd diary.
# Sonarr cleanup additionally requires SONARR_ENABLED=true above.
# RADARR_CLEANUP_ENABLED=false
# SONARR_CLEANUP_ENABLED=false
# Your Letterboxd username (required when either cleanup is enabled)
# LETTERBOXD_USERNAME=your_username
# Letterboxd diary tag to watch for (shared by Radarr and Sonarr cleanup)
# LETTERBOXD_CLEANUP_TAG=cleanup

# Dry run mode (true to simulate actions without making changes, false to perform actual operations)
# DRY_RUN=true
